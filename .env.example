# Copy this file to .env and fill in real values. Never commit .env.

# Skip the CRA preflight check when running the frontend build from the root script
SKIP_PREFLIGHT_CHECK=true

# Secret used to sign JSON Web Tokens for authenticated sessions
JWT_SECRET=change_me_to_a_long_random_string

# PayPal REST API client ID (sandbox or live), used for checkout
PAYPAL_CLIENT_ID=your_paypal_client_id

# MongoDB connection string (e.g. a MongoDB Atlas URI)
MONGODB_URL=mongodb+srv://<username>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority

# Google Maps JavaScript API key, used by the backend /api/config/google endpoint
GOOGLE_API_KEY=your_google_maps_api_key

# Port the Express server listens on (optional, defaults to 5000)
PORT=5000
